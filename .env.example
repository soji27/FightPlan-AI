# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# URL du service Ollama (LLM local)
OLLAMA_HOST=

# URL du service ChromaDB (base vectorielle)
CHROMA_HOST=

# Modele LLM a utiliser via Ollama
OLLAMA_MODEL=

# Modele d'embeddings a utiliser via Ollama
EMBED_MODEL=

# Chemin vers le fichier CSV des combats UFC
CSV_PATH=

# Longueur maximale d'un message utilisateur (securite)
MAX_INPUT_LENGTH=

# Nom de la collection ChromaDB
CHROMA_COLLECTION=
